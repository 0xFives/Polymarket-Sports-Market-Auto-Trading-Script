{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",

    "rootDir": "src",
    "outDir": "dist",

    "baseUrl": ".",
    "paths": {
      "polymarket-onchain-sdk": ["node_modules/polymarket-onchain-sdk/src/index.ts"],
      "polymarket-onchain-sdk/*": ["node_modules/polymarket-onchain-sdk/src/*"]
    },

    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,
    "removeComments": false
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
  