# =============================================================================
# Polymarket copytrade bot — environment template
# =============================================================================
# Usage: copy to ".env" and set values. Loaded by src/config/index.ts via dotenv.
# Never commit .env (PRIVATE_KEY). This file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# Hex private key for the trading wallet (0x-prefixed or raw). Used for CLOB auth
# and on-chain actions. Store only on trusted machines.
PRIVATE_KEY=

# -----------------------------------------------------------------------------
# RPC (recommended for startup allowances, balance sync, redemption scripts)
# -----------------------------------------------------------------------------
# Polygon HTTPS endpoint (e.g. Alchemy, Infura). Optional but many flows need it.
# RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_TOKEN=

# -----------------------------------------------------------------------------
# Wallet mode
# -----------------------------------------------------------------------------
# false = EOA signs and holds balances (default). true = Polymarket proxy profile.
USE_PROXY_WALLET=false
# Required when USE_PROXY_WALLET=true — USDC/holdings address on Polymarket.
# PROXY_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# Network & API
# -----------------------------------------------------------------------------
CHAIN_ID=137
CLOB_API_URL=https://clob.polymarket.com
# Global neg-risk flag for some on-chain allowance paths (see project docs).
NEG_RISK=false

# -----------------------------------------------------------------------------
# Bot runner (src/index.ts)
# -----------------------------------------------------------------------------
# Minimum available USDC before the process proceeds (polls until satisfied).
BOT_MIN_USDC_BALANCE=1
# If true, sleep until the next 15m boundary before attaching markets.
COPYTRADE_WAIT_FOR_NEXT_MARKET_START=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
DEBUG=false
LOG_DIR=logs
LOG_FILE_PREFIX=bot
# Optional: single path; "{date}" expands for daily files (see README).
# LOG_FILE_PATH=logs/bot-{date}.log

# -----------------------------------------------------------------------------
# Copytrade — markets & order sizing
# -----------------------------------------------------------------------------
# Comma-separated 15m Up/Down symbols (slug prefix), lowercase: btc, eth, sol, ...
COPYTRADE_MARKETS=btc
COPYTRADE_SHARES=5
COPYTRADE_TICK_SIZE=0.01
COPYTRADE_NEG_RISK=false
# Added to first-leg limit price (on top of best-ask offset); use small values.
COPYTRADE_PRICE_BUFFER=0
# If true, less blocking on order responses (faster, less confirmation in-process).
COPYTRADE_FIRE_AND_FORGET=true
COPYTRADE_MIN_BALANCE_USDC=1
# 0 = no cap. >0 pauses a slug after that many buys per side (UP/DOWN).
COPYTRADE_MAX_BUY_COUNTS_PER_SIDE=0

# -----------------------------------------------------------------------------
# Copytrade — hedge safety (optional)
# -----------------------------------------------------------------------------
# Second leg: limit (GTC at 0.98 − first price) or taker (CLOB market FOK/FAK).
COPYTRADE_HEDGE_SECOND_LEG=limit
# FOK = fill full size or cancel. FAK = allow partial fill.
COPYTRADE_HEDGE_TAKER_ORDER_TYPE=FOK
# USDC budget multiplier vs best_ask × shares for taker hedge (slippage headroom).
COPYTRADE_HEDGE_TAKER_SLIPPAGE=1.1
# Milliseconds to wait for first-leg matches before posting taker hedge; 0 = immediate.
COPYTRADE_HEDGE_WAIT_FIRST_FILL_MS=0
# Limit hedge only: if hedge not fully matched within this window (ms), cancel legs
# and FAK-sell any filled first-leg size. 0 disables the unwind watcher.
COPYTRADE_HEDGE_UNWIND_TIMEOUT_MS=0
COPYTRADE_HEDGE_UNWIND_POLL_MS=150

# -----------------------------------------------------------------------------
# Redeem scripts only (npm run redeem / redeem:holdings)
# -----------------------------------------------------------------------------
# CONDITION_ID=
# INDEX_SETS=

# -----------------------------------------------------------------------------
# Legacy aliases (optional — prefer COPYTRADE_* above)
# -----------------------------------------------------------------------------
# GABAGOOL_MARKETS=
# GABAGOOL_SHARES=
# GABAGOOL_TICK_SIZE=
# GABAGOOL_NEG_RISK=
